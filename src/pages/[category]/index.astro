---
import { getCollection } from 'astro:content';
import PaginatedArticleList from '../../components/PaginatedArticleList.astro';
import Sidebar from '../../components/Sidebar.astro';
import {
  docsCategories,
  docsCategoryDataMap,
  docsParentCategories,
  docsParentMap,
  getArticleHref,
  getCategoriesForParent,
  getCategoryHref,
  getCleanDocSlug,
  getParentForCategory,
} from '../../data/docs';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    ...docsParentCategories.map((category) => ({
      params: { category: category.slug },
    })),
    ...docsCategories.map((category) => ({
      params: { category: category.slug },
    })),
  ];
}

const { category } = Astro.params;
const allDocs = await getCollection('docs');
const searchIndex = allDocs.map((doc) => {
  const cleanSlug = getCleanDocSlug(doc.id);
  return {
    title: doc.data.title,
    description: doc.data.description ?? '',
    category: docsCategoryDataMap[doc.data.category as keyof typeof docsCategoryDataMap]?.name ?? doc.data.category,
    url: getArticleHref(doc.data.category, cleanSlug),
  };
});

const buildSidebarSections = (parentSlug: string) =>
  getCategoriesForParent(parentSlug).map((section) => ({
    name: section.name,
    slug: section.slug,
    href: getCategoryHref(section.slug),
  }));

const parentData = category ? docsParentMap[category as keyof typeof docsParentMap] : undefined;
const isParentView = Boolean(parentData);

const subcategory = !isParentView && category
  ? docsCategoryDataMap[category as keyof typeof docsCategoryDataMap]
  : undefined;
const parentSlug = subcategory ? getParentForCategory(subcategory.slug) : parentData?.slug;
const parent = parentSlug ? docsParentMap[parentSlug] : parentData;
const sections = parent ? buildSidebarSections(parent.slug) : [];
const categoryDocs = allDocs
  .filter((doc) => doc.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${isParentView ? parentData?.name : subcategory?.name ?? category} | Compass`}>
    <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 md:flex-row md:px-8">
      {parent && (
        <Sidebar
          sections={sections}
          activeCategory={subcategory?.slug}
          searchIndex={searchIndex}
        />
      )}

      <div class="min-w-0 flex-1">
        {isParentView && parentData ? (
          <section class="site-panel rounded-none border border-[var(--color-border)] bg-[var(--color-surface)] p-8 md:p-10">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Category</p>
            <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">{parentData.name}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">{parentData.description}</p>

            <div class="mt-10 space-y-10">
              {sections.map((section) => (
                <section>
                  <a
                    href={section.href}
                    class="docs-article-link text-2xl font-semibold tracking-tight text-slate-900 transition hover:text-[var(--color-accent)]"
                  >
                    {section.name}
                  </a>
                  <div class="mt-4">
                    <PaginatedArticleList
                      idPrefix={`parent-${parentData.slug}-${section.slug}`}
                      pageSize={6}
                      itemClassName="docs-article-list-link block px-4 py-3 text-sm text-slate-700 transition hover:text-[var(--color-accent)]"
                      items={allDocs
                      .filter((doc) => doc.data.category === section.slug)
                      .sort((a, b) => a.data.order - b.data.order)
                      .map((article) => ({
                        title: article.data.title,
                        href: getArticleHref(section.slug, getCleanDocSlug(article.id)),
                      }))}
                    />
                  </div>
                </section>
              ))}
            </div>
          </section>
        ) : (
          <section class="site-panel rounded-none border border-[var(--color-border)] bg-[var(--color-surface)] p-8 md:p-10">
            <h1 class="text-4xl font-semibold tracking-tight text-slate-950">{subcategory?.name ?? category}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
              {subcategory?.description ?? 'Browse the articles in this section and jump into the topic you need.'}
            </p>

            {categoryDocs.length === 0 ? (
              <div class="category-empty mt-10 rounded-none bg-[var(--color-surface-muted)] px-6 py-14 text-center text-slate-500">
                No articles yet. Add MDX files in <code>src/content/docs/{category}</code> to populate this section.
              </div>
            ) : (
              <div class="docs-divider mt-10 border-t border-[var(--color-border)] pt-6">
                <PaginatedArticleList
                  idPrefix={`category-${subcategory?.slug ?? category}`}
                  pageSize={8}
                  items={categoryDocs.map((doc) => ({
                    title: doc.data.title,
                    href: getArticleHref(doc.data.category, getCleanDocSlug(doc.id)),
                  }))}
                />
              </div>
            )}
          </section>
        )}
      </div>
    </div>
</Layout>
