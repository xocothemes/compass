---
// Note: This file handles both top-level category slugs (e.g. `/start-here`)
// and parent category slugs (e.g. `/getting-started`). The routes
// `src/pages/[parent]/[category]/index.astro` and
// `src/pages/[parent]/[category]/[slug].astro` also exist and are built by
// Astro. They produce different URL paths (e.g. `/getting-started/start-here`).
// Keep the dual-behavior intentionally - don't remove parent-handling
// here without checking those sibling route files.
import { getCollection } from 'astro:content';
import PaginatedArticleList from '../../components/PaginatedArticleList.astro';
import Sidebar from '../../components/Sidebar.astro';
import {
  docsCategories,
  docsCategoryDataMap,
  docsParentCategories,
  docsParentMap,
  getArticleHref,
  getCleanDocSlug,
  getOrderedDocsForCategory,
  getParentForCategory,
  getPublicDocs,
  getSearchPreviewLookup,
  getSidebarSections,
  getSuggestedSearchArticles,
} from '../../data/docs';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    ...docsParentCategories.map((category) => ({
      params: { category: category.slug },
    })),
    ...docsCategories.map((category) => ({
      params: { category: category.slug },
    })),
  ];
}

const { category } = Astro.params;
const allDocs = await getCollection('docs');
const publicDocs = getPublicDocs(allDocs);
const parentData = category ? docsParentMap[category as keyof typeof docsParentMap] : undefined;
const isParentView = Boolean(parentData);

const subcategory =
  !isParentView && category ? docsCategoryDataMap[category as keyof typeof docsCategoryDataMap] : undefined;
const parentSlug = subcategory ? getParentForCategory(subcategory.slug) : parentData?.slug;
const parent = parentSlug ? docsParentMap[parentSlug] : parentData;
const sections = parent ? getSidebarSections(parent.slug) : [];
const categoryDocs = category ? getOrderedDocsForCategory(publicDocs, category) : [];
const suggestedArticles =
  isParentView && parent
    ? getSuggestedSearchArticles(publicDocs, {
        limit: 3,
        categories: sections.map((section) => section.slug),
      })
    : getSuggestedSearchArticles(publicDocs, {
        limit: 3,
        categories: category ? [category] : undefined,
      });
const searchPreviews = getSearchPreviewLookup(publicDocs);
---

<Layout title={`${isParentView ? parentData?.name : (subcategory?.name ?? category)} | Compass`}>
  <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 lg:flex-row lg:px-8">
    {
      parent && (
        <Sidebar
          sections={sections}
          activeCategory={subcategory?.slug}
          suggestions={suggestedArticles}
          searchPreviews={searchPreviews}
        />
      )
    }

    <div class="min-w-0 flex-1">
      {
        isParentView && parentData ? (
          <section class="site-panel rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 lg:p-10">
            <nav class="docs-breadcrumbs mb-6 flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
              <a href="/" class="breadcrumb-link transition hover:text-[var(--color-accent)]">
                Home
              </a>
              <span>/</span>
              <span class="breadcrumb-current text-[var(--color-text-strong)]">{parentData.name}</span>
            </nav>
            <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-text-strong)]">{parentData.name}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-text)]">{parentData.description}</p>

            <div class="mt-10 space-y-10">
              {sections.map((section) => (
                <section>
                  <a
                    href={section.href}
                    class="docs-article-link text-2xl font-semibold tracking-tight text-[var(--color-link-subtle)] transition hover:text-[var(--color-accent)]"
                  >
                    {section.name}
                  </a>
                  <div class="mt-4">
                    <ol class="space-y-1">
                      {getOrderedDocsForCategory(publicDocs, section.slug).map((article, index) => (
                        <li>
                          <a
                            href={getArticleHref(section.slug, getCleanDocSlug(article.id))}
                            class="docs-article-list-link grid grid-cols-[2rem_minmax(0,1fr)] items-center gap-x-3 py-2 text-sm text-[var(--color-link-subtle)] transition hover:text-[var(--color-accent)]"
                          >
                            <span class="self-center text-right text-xs font-semibold leading-none text-[var(--color-text-muted)]">
                              {String(index + 1).padStart(2, '0')}
                            </span>
                            <span class="leading-6">{article.data.title}</span>
                          </a>
                        </li>
                      ))}
                    </ol>
                  </div>
                </section>
              ))}
            </div>
          </section>
        ) : (
          <section class="site-panel rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 lg:p-10">
            <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-text-strong)]">
              {subcategory?.name ?? category}
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-text)]">
              {subcategory?.description ?? 'Browse the articles in this section and jump into the topic you need.'}
            </p>

            {categoryDocs.length === 0 ? (
              <div class="category-empty mt-10 rounded-[15px] bg-[var(--color-surface-muted)] px-6 py-14 text-center text-[var(--color-text-muted)]">
                No articles yet. Add MDX files in <code>src/content/docs/{category}</code> to populate this section.
              </div>
            ) : (
              <div class="docs-divider mt-10 border-t border-[var(--color-border)] pt-6">
                <PaginatedArticleList
                  pageSize={8}
                  items={categoryDocs.map((doc) => ({
                    title: doc.data.title,
                    href: getArticleHref(doc.data.category, getCleanDocSlug(doc.id)),
                  }))}
                />
              </div>
            )}
          </section>
        )
      }
    </div>
  </div>
</Layout>
