---
import { getCollection } from 'astro:content';
import PaginatedArticleList from '../../../components/PaginatedArticleList.astro';
import Sidebar from '../../../components/Sidebar.astro';
import {
  docsCategoryDataMap,
  docsParentMap,
  getArticleHref,
  getCategoriesForParent,
  getCategoryHref,
  getCleanDocSlug,
} from '../../../data/docs';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return Object.values(docsCategoryDataMap).map((category) => ({
    params: {
      parent: category.parent,
      category: category.slug,
    },
  }));
}

const { parent: parentSlug, category } = Astro.params;
const parent = parentSlug ? docsParentMap[parentSlug as keyof typeof docsParentMap] : undefined;
const subcategory = category ? docsCategoryDataMap[category as keyof typeof docsCategoryDataMap] : undefined;
const allDocs = await getCollection('docs');
const sections = parent ? getCategoriesForParent(parent.slug).map((section) => ({
  name: section.name,
  slug: section.slug,
  href: getCategoryHref(section.slug),
})) : [];
const searchIndex = allDocs.map((doc) => ({
  title: doc.data.title,
  description: doc.data.description ?? '',
  category: docsCategoryDataMap[doc.data.category as keyof typeof docsCategoryDataMap]?.name ?? doc.data.category,
  url: getArticleHref(doc.data.category, getCleanDocSlug(doc.id)),
}));
const categoryDocs = allDocs
  .filter((doc) => doc.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${subcategory?.name ?? category} | ${parent?.name ?? 'Compass'}`}>
  <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 md:flex-row md:px-8">
    {parent && (
      <Sidebar
        sections={sections}
        activeCategory={subcategory?.slug}
        searchIndex={searchIndex}
      />
    )}

    <div class="min-w-0 flex-1">
      <section class="site-panel rounded-none border border-[var(--color-border)] bg-[var(--color-surface)] p-8 md:p-10">
        <nav class="docs-breadcrumbs mb-6 flex flex-wrap items-center gap-2 text-sm text-slate-500">
          <a href="/" class="breadcrumb-link transition hover:text-slate-950">Home</a>
          <span>/</span>
          {parent && <a href={`/${parent.slug}`} class="breadcrumb-link transition hover:text-slate-950">{parent.name}</a>}
          <span>/</span>
          <span class="breadcrumb-current text-slate-700">{subcategory?.name ?? category}</span>
        </nav>

        <h1 class="text-4xl font-semibold tracking-tight text-slate-950">{subcategory?.name ?? category}</h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
          {subcategory?.description ?? 'Browse the articles in this section and jump into the topic you need.'}
        </p>

        {categoryDocs.length === 0 ? (
          <div class="category-empty mt-10 rounded-none bg-[var(--color-surface-muted)] px-6 py-14 text-center text-slate-500">
            No articles yet. Add MDX files in <code>src/content/docs/{category}</code> to populate this section.
          </div>
        ) : (
          <div class="docs-divider mt-10 border-t border-[var(--color-border)] pt-6">
            <PaginatedArticleList
              idPrefix={`nested-category-${subcategory?.slug ?? category}`}
              pageSize={8}
              items={categoryDocs.map((doc) => ({
                title: doc.data.title,
                href: getArticleHref(doc.data.category, getCleanDocSlug(doc.id)),
              }))}
            />
          </div>
        )}
      </section>
    </div>
  </div>
</Layout>
