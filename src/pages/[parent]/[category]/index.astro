---
import { getCollection } from 'astro:content';
import PaginatedArticleList from '../../../components/PaginatedArticleList.astro';
import Sidebar from '../../../components/Sidebar.astro';
import {
  docsCategoryDataMap,
  docsParentMap,
  getArticleHref,
  getCleanDocSlug,
  getOrderedDocsForCategory,
  getSearchPreviewLookup,
  getSidebarSections,
  getSuggestedSearchArticles,
} from '../../../data/docs';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return Object.values(docsCategoryDataMap).map((category) => ({
    params: {
      parent: category.parent,
      category: category.slug,
    },
  }));
}

const { parent: parentSlug, category } = Astro.params;
const parent = parentSlug ? docsParentMap[parentSlug as keyof typeof docsParentMap] : undefined;
const subcategory = category ? docsCategoryDataMap[category as keyof typeof docsCategoryDataMap] : undefined;
const allDocs = await getCollection('docs');
const sections = parent ? getSidebarSections(parent.slug) : [];
const categoryDocs = category ? getOrderedDocsForCategory(allDocs, category) : [];
const suggestedArticles = getSuggestedSearchArticles(allDocs, {
  limit: 3,
  categories: category ? [category] : undefined,
});
const searchPreviews = getSearchPreviewLookup(allDocs);
---

<Layout title={`${subcategory?.name ?? category} | ${parent?.name ?? 'Compass'}`}>
  <div class="mx-auto flex max-w-[1280px] flex-col gap-10 px-4 py-10 lg:flex-row lg:px-8">
    {parent && (
      <Sidebar
        sections={sections}
        activeCategory={subcategory?.slug}
        suggestions={suggestedArticles}
        searchPreviews={searchPreviews}
      />
    )}

    <div class="min-w-0 flex-1">
      <section class="site-panel rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 lg:p-10">
        <nav class="docs-breadcrumbs mb-6 flex flex-wrap items-center gap-2 text-sm text-[var(--color-text-muted)]">
          <a href="/" class="breadcrumb-link transition hover:text-[var(--color-accent)]">Home</a>
          <span>/</span>
          {parent && <a href={`/${parent.slug}`} class="breadcrumb-link transition hover:text-[var(--color-accent)]">{parent.name}</a>}
          <span>/</span>
          <span class="breadcrumb-current text-[var(--color-text-strong)]">{subcategory?.name ?? category}</span>
        </nav>

        <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-text-strong)]">{subcategory?.name ?? category}</h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-[var(--color-text)]">
          {subcategory?.description ?? 'Browse the articles in this section and jump into the topic you need.'}
        </p>

        {categoryDocs.length === 0 ? (
          <div class="category-empty mt-10 rounded-[15px] bg-[var(--color-surface-muted)] px-6 py-14 text-center text-[var(--color-text-muted)]">
            No articles yet. Add MDX files in <code>src/content/docs/{category}</code> to populate this section.
          </div>
        ) : (
          <div class="docs-divider mt-10 border-t border-[var(--color-border)] pt-6">
            <PaginatedArticleList
              pageSize={8}
              items={categoryDocs.map((doc) => ({
                title: doc.data.title,
                href: getArticleHref(doc.data.category, getCleanDocSlug(doc.id)),
              }))}
            />
          </div>
        )}
      </section>
    </div>
  </div>
</Layout>
