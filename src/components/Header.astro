---
import site from '../../site.config.mjs';
import { docsParentCategories } from '../data/docs';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActiveNavItem(href: string) {
  const normalizedHref = href.replace(/\/+$/, '') || '/';
  return pathname === normalizedHref || pathname.startsWith(`${normalizedHref}/`);
}
---

<header
  class="site-header sticky top-0 z-40 w-full shrink-0 border-b border-[var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-surface)_95%,transparent)] backdrop-blur"
>
  <div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between px-4 md:px-8">
    <a
      href="/"
      class="text-2xl font-bold tracking-tight text-[var(--color-text-strong)] transition-opacity hover:opacity-80"
    >
      {site.name}
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-[var(--color-text)] lg:flex">
      {
        docsParentCategories.map((category) =>
          (() => {
            const href = `/${category.slug}`;
            const isActive = isActiveNavItem(href);

            return (
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'py-5 transition-colors',
                  isActive ? 'text-[var(--color-accent)]' : 'hover:text-[var(--color-accent)]',
                ]}
              >
                {category.name}
              </a>
            );
          })(),
        )
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <button
        type="button"
        class="theme-toggle inline-flex h-10 w-10 items-center justify-center rounded-[15px] bg-transparent text-[var(--color-control-text)] transition hover:bg-transparent"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <svg
          class="theme-toggle-moon h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.354 15.354A9 9 0 0 1 8.646 3.646a9 9 0 1 0 11.708 11.708Z"></path>
        </svg>
        <svg
          class="theme-toggle-sun hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3.75v2.5M12 17.75v2.5M18.25 12h2.5M3.25 12h2.5M17.127 6.873l1.768-1.768M5.105 18.895l1.768-1.768M17.127 17.127l1.768 1.768M5.105 5.105l1.768 1.768M15.25 12A3.25 3.25 0 1 1 8.75 12a3.25 3.25 0 0 1 6.5 0Z"
          ></path>
        </svg>
      </button>

      <a
        href={site.navCtaHref}
        target="_blank"
        rel="noreferrer"
        class="hidden rounded-[15px] bg-[var(--color-brand)] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-hover)] lg:inline-flex"
      >
        {site.navCtaLabel}
      </a>
    </div>

    <div class="flex items-center gap-2 lg:hidden">
      <button
        type="button"
        class="theme-toggle inline-flex h-10 w-10 items-center justify-center rounded-[15px] bg-transparent text-[var(--color-control-text)] transition hover:bg-transparent"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <svg
          class="theme-toggle-moon h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.354 15.354A9 9 0 0 1 8.646 3.646a9 9 0 1 0 11.708 11.708Z"></path>
        </svg>
        <svg
          class="theme-toggle-sun hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3.75v2.5M12 17.75v2.5M18.25 12h2.5M3.25 12h2.5M17.127 6.873l1.768-1.768M5.105 18.895l1.768-1.768M17.127 17.127l1.768 1.768M5.105 5.105l1.768 1.768M15.25 12A3.25 3.25 0 1 1 8.75 12a3.25 3.25 0 0 1 6.5 0Z"
          ></path>
        </svg>
      </button>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-[15px] bg-transparent text-[var(--color-control-text)] transition"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        aria-label="Toggle menu"
      >
        <svg
          class="mobile-menu-icon-open h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          class="mobile-menu-icon-close hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6 6 18"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu-panel" class="hidden border-t border-[var(--color-border)] bg-[var(--color-surface)] lg:hidden">
    <div class="mx-auto max-w-[1280px] px-4 py-4 md:px-8">
      <nav class="flex flex-col gap-1">
        {
          docsParentCategories.map((category) =>
            (() => {
              const href = `/${category.slug}`;
              const isActive = isActiveNavItem(href);

              return (
                <a
                  href={href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'block w-full rounded-[15px] px-4 py-3 text-sm font-medium transition-colors',
                    isActive
                      ? 'bg-[var(--color-hover-surface)] text-[var(--color-accent)]'
                      : 'text-[var(--color-text)] hover:bg-[var(--color-hover-surface)] hover:text-[var(--color-accent)]',
                  ]}
                >
                  {category.name}
                </a>
              );
            })(),
          )
        }
      </nav>

      <div class="mt-4">
        <a
          href={site.navCtaHref}
          target="_blank"
          rel="noreferrer"
          class="inline-flex w-full items-center justify-center rounded-[15px] bg-[var(--color-brand)] px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-hover)]"
        >
          {site.navCtaLabel}
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');

  if (mobileMenuToggle instanceof HTMLButtonElement && mobileMenuPanel instanceof HTMLDivElement) {
    const openIcon = mobileMenuToggle.querySelector('.mobile-menu-icon-open');
    const closeIcon = mobileMenuToggle.querySelector('.mobile-menu-icon-close');

    const setMobileMenuOpen = (isOpen) => {
      mobileMenuPanel.classList.toggle('hidden', !isOpen);
      mobileMenuToggle.setAttribute('aria-expanded', String(isOpen));
      openIcon?.classList.toggle('hidden', isOpen);
      closeIcon?.classList.toggle('hidden', !isOpen);
    };

    mobileMenuToggle.addEventListener('click', () => {
      const isOpen = !mobileMenuPanel.classList.contains('hidden');
      setMobileMenuOpen(!isOpen);
    });

    mobileMenuPanel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        setMobileMenuOpen(false);
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMobileMenuOpen(false);
      }
    });

    mobileMenuPanel.addEventListener('focusout', (event) => {
      const nextTarget = event.relatedTarget;
      if (nextTarget instanceof Node && mobileMenuPanel.contains(nextTarget)) return;
      if (nextTarget === mobileMenuToggle) return;
      setMobileMenuOpen(false);
    });
  }

  const root = document.documentElement;
  const themeToggleButtons = document.querySelectorAll('.theme-toggle');

  const syncThemeButtons = () => {
    const isDark = root.classList.contains('dark');

    themeToggleButtons.forEach((button) => {
      const moonIcon = button.querySelector('.theme-toggle-moon');
      const sunIcon = button.querySelector('.theme-toggle-sun');

      moonIcon?.classList.toggle('hidden', isDark);
      sunIcon?.classList.toggle('hidden', !isDark);
      button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
      button.setAttribute('title', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    });

    window.__syncCompassFavicon?.(isDark);
  };

  syncThemeButtons();

  themeToggleButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextTheme = root.classList.contains('dark') ? 'light' : 'dark';
      root.classList.toggle('dark', nextTheme === 'dark');
      localStorage.setItem('compass-theme', nextTheme);
      syncThemeButtons();
    });
  });
</script>
