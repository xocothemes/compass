---
interface Props {
  slug?: string;
  title: string;
  description?: string;
}

const { slug, title, description } = Astro.props;
---

<section id={slug} class="mx-auto max-w-[1280px] px-4 py-8 md:px-8 md:py-10">
  <div class="mb-5">
    <h2 class="category-section-title text-3xl font-bold tracking-tight text-[var(--color-text-strong)]">{title}</h2>
    {
      description && (
        <p class="category-section-description mt-2 text-sm leading-6 text-[var(--color-text-muted)]">{description}</p>
      )
    }
  </div>
  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
    <slot />
  </div>
</section>
