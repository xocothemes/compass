---
interface SidebarSection {
  name: string;
  slug: string;
  href: string;
}

interface Props {
  sections: SidebarSection[];
  activeCategory?: string;
  suggestions?: {
    title: string;
    excerpt: string;
    category: string;
    url: string;
  }[];
  searchPreviews?: Record<string, string>;
}

const { sections, activeCategory, suggestions = [], searchPreviews = {} } = Astro.props;
const searchId = `sidebar-search-${Math.random().toString(36).slice(2, 10)}`;
---

<aside class="docs-sidebar w-full shrink-0 lg:sticky lg:top-24 lg:w-72">
  <div
    class="relative"
    role="search"
    data-docs-search
    data-search-empty="No matching articles found."
    data-search-error="Search is available after running npm run build and npm run preview."
    data-search-suggestions={JSON.stringify(suggestions)}
    data-search-previews={JSON.stringify(searchPreviews)}
  >
    <label class="sr-only" for={`${searchId}-input`}>Search this docs section</label>
    <p id={`${searchId}-hint`} class="sr-only">Type to search articles in this section. Press slash or Control/Command plus K to focus the nearest search field.</p>
    <p id={`${searchId}-status`} class="sr-only" data-search-status aria-live="polite"></p>
    <input
      id={`${searchId}-input`}
      type="search"
      placeholder="Search..."
      data-search-input
      class="sidebar-search-input w-full rounded-[15px] border border-[var(--color-border-strong)] bg-[var(--color-surface)] py-3 pl-4 pr-10 text-sm text-[var(--color-search-text)] outline-none placeholder:text-[var(--color-search-placeholder)] focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20"
      aria-describedby={`${searchId}-hint ${searchId}-status`}
      aria-controls={`${searchId}-results`}
      aria-expanded="false"
    />
    <div class="sidebar-search-icon pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-[var(--color-search-placeholder)]">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
      </svg>
    </div>
    <div
      id={`${searchId}-results`}
      data-search-results
      class="sidebar-search-results absolute left-0 right-0 top-full z-50 mt-2 hidden max-h-80 overflow-y-auto rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] text-left"
      role="region"
      aria-label="Search results"
      aria-hidden="true"
    ></div>
  </div>

  <div class="mt-8 hidden lg:block">
    <p class="font-mono text-xs font-normal text-[var(--color-ui-label)]">Categories</p>
    <ul class="mt-5 space-y-1">
      {sections.map((section) => {
        const isActiveSection = activeCategory === section.slug;

        return (
          <li>
            <a
              href={section.href}
              aria-current={isActiveSection ? 'page' : undefined}
              class={`sidebar-link block rounded-[15px] px-3 py-2.5 text-sm font-medium transition ${
                isActiveSection
                  ? 'is-active text-[var(--color-accent)]'
                  : 'text-[var(--color-text)] hover:bg-[var(--color-hover-surface)] hover:text-[var(--color-text-strong)]'
              }`}
            >
              {section.name}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</aside>

<script>
  import '../scripts/docs-search';
</script>
