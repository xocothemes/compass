---
import type { SidebarSection } from '../data/docs';

interface Props {
  sections: SidebarSection[];
  activeCategory?: string;
  tocHeadings?: {
    depth: number;
    slug: string;
    text: string;
  }[];
  suggestions?: {
    title: string;
    excerpt: string;
    url: string;
  }[];
}

const { sections, activeCategory, tocHeadings = [], suggestions = [] } = Astro.props;
const searchId = `sidebar-search-${Math.random().toString(36).slice(2, 10)}`;
---

<aside
  class="docs-sidebar w-full shrink-0 lg:sticky lg:top-[calc(var(--docs-header-height)+1rem)] lg:max-h-[calc(100vh-var(--docs-header-height)-1.5rem)] lg:w-72 lg:overflow-y-auto lg:pr-1"
>
  <div
    class="relative"
    role="search"
    data-docs-search
    data-search-empty="No matching articles found."
    data-search-error="Search is available after running npm run build and npm run preview."
    data-search-suggestions={JSON.stringify(suggestions)}
  >
    <label class="sr-only" for={`${searchId}-input`}>Search this docs section</label>
    <p id={`${searchId}-hint`} class="sr-only">
      Type to search articles in this section. Press slash or Control/Command plus K to focus the nearest search field.
    </p>
    <p id={`${searchId}-status`} class="sr-only" data-search-status aria-live="polite"></p>
    <input
      id={`${searchId}-input`}
      type="search"
      placeholder="Search..."
      data-search-input
      class="sidebar-search-input w-full rounded-[15px] border border-[var(--color-border-strong)] bg-[var(--color-surface)] py-3 pl-4 pr-10 text-sm text-[var(--color-search-text)] outline-none placeholder:text-[var(--color-search-placeholder)] focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20"
      aria-describedby={`${searchId}-hint ${searchId}-status`}
    />
    <div
      class="sidebar-search-icon pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-[var(--color-search-placeholder)]"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z"></path>
      </svg>
    </div>
    <div
      id={`${searchId}-results`}
      data-search-results
      class="sidebar-search-results absolute left-0 right-0 top-full z-50 mt-2 hidden max-h-80 overflow-y-auto rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] text-left"
      role="region"
      aria-label="Search results"
      aria-hidden="true"
    >
    </div>
  </div>

  <div class="mt-8 hidden lg:block">
    <p class="docs-ui-label">Categories</p>
    <ul class="docs-sidebar-section-list mt-5">
      {
        sections.map((section) => {
          const isActiveSection = activeCategory === section.slug;

          return (
            <li>
              <a
                href={section.href}
                aria-current={isActiveSection ? 'page' : undefined}
                class={`sidebar-link docs-sidebar-section-link block rounded-[15px] px-3 text-sm font-medium transition ${
                  isActiveSection
                    ? 'is-active text-[var(--color-accent)]'
                    : 'text-[var(--color-text)] hover:text-[var(--color-accent)]'
                }`}
              >
                {section.name}
              </a>
            </li>
          );
        })
      }
    </ul>

    {
      tocHeadings.length > 0 && (
        <nav class="docs-sidebar-toc mt-7" aria-label="Table of contents">
          <p class="docs-toc-title">On this page</p>
          <ol class="docs-toc-list docs-sidebar-toc-list">
            {tocHeadings.map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  data-toc-link={heading.slug}
                  class:list={['docs-toc-link', heading.depth === 3 && 'docs-toc-link-subheading']}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
  </div>
</aside>

<script>
  import '../scripts/docs-search';
</script>
