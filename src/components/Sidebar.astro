---
interface SidebarSection {
  name: string;
  slug: string;
  href: string;
}

interface SearchEntry {
  title: string;
  description: string;
  url: string;
  category: string;
}

interface Props {
  sections: SidebarSection[];
  activeCategory?: string;
  searchIndex: SearchEntry[];
}

const { sections, activeCategory, searchIndex } = Astro.props;
---

<aside class="docs-sidebar w-full shrink-0 md:sticky md:top-24 md:w-72">
  <div class="relative">
    <input
      id="docs-sidebar-search"
      type="search"
      placeholder="Search"
      class="sidebar-search-input w-full rounded-none border border-[var(--color-border-strong)] bg-[var(--color-surface)] py-3 pl-4 pr-10 text-sm text-[var(--color-search-text)] outline-none placeholder:text-[var(--color-search-placeholder)] focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20"
    />
    <div class="sidebar-search-icon pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-[var(--color-search-placeholder)]">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
      </svg>
    </div>
    <div
      id="docs-sidebar-results"
      class="sidebar-search-results absolute left-0 right-0 top-full z-50 mt-2 hidden max-h-80 overflow-y-auto rounded-none border border-[var(--color-border)] bg-[var(--color-surface)] text-left"
    ></div>
  </div>

  <div class="mt-8">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Categories</p>
    <ul class="mt-5 space-y-1">
      {sections.map((section) => {
        const isActiveSection = activeCategory === section.slug;

        return (
          <li>
            <a
              href={section.href}
              class={`sidebar-link block rounded-none px-3 py-2.5 text-sm font-medium transition ${
                isActiveSection
                  ? 'is-active text-[var(--color-accent)]'
                  : 'text-slate-700 hover:bg-[var(--color-hover-surface)] hover:text-slate-950'
              }`}
            >
              {section.name}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</aside>

<script is:inline define:vars={{ searchIndex }}>
  const sidebarInput = document.getElementById('docs-sidebar-search');
  const sidebarResults = document.getElementById('docs-sidebar-results');

  if (sidebarInput instanceof HTMLInputElement && sidebarResults instanceof HTMLDivElement) {
    sidebarInput.addEventListener('input', () => {
      const query = sidebarInput.value.toLowerCase().trim();

      if (!query) {
        sidebarResults.classList.add('hidden');
        sidebarResults.innerHTML = '';
        return;
      }

      const results = searchIndex
        .filter((entry) =>
          [entry.title, entry.description, entry.category].some((value) =>
            value.toLowerCase().includes(query),
          ),
        )
        .slice(0, 8);

      sidebarResults.classList.remove('hidden');

      if (results.length === 0) {
        sidebarResults.innerHTML = '<p class="px-4 py-4 text-sm text-slate-500">No matching articles found.</p>';
        return;
      }

      sidebarResults.innerHTML = results
        .map(
          (result) => `
            <a href="${result.url}" class="block px-4 py-3 transition-colors hover:bg-[var(--color-hover-surface)]">
              <div class="text-sm font-medium text-[var(--color-accent)]">${result.title}</div>
              <div class="mt-1 text-xs text-slate-500">${result.category}${result.description ? ' - ' + result.description : ''}</div>
            </a>
          `,
        )
        .join('');
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!sidebarInput.contains(target) && !sidebarResults.contains(target)) {
        sidebarResults.classList.add('hidden');
      }
    });
  }
</script>
