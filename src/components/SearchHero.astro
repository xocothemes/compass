---
interface Props {
  id?: string;
  title?: string;
  placeholder?: string;
  suggestions?: {
    title: string;
    excerpt: string;
    url: string;
  }[];
}

const {
  id = 'search-hero',
  title = 'How can we help?',
  placeholder = 'Search the docs...',
  suggestions = [],
} = Astro.props;
const inputId = `${id}-input`;
const resultsId = `${id}-results`;
const hintId = `${id}-hint`;
const statusId = `${id}-status`;
---

<section class="search-hero bg-[var(--color-surface)] py-14 md:py-16">
  <div class="mx-auto w-full max-w-[1280px] px-4 text-center md:px-8">
    <h1
      class="search-hero-title mb-6 text-4xl font-extrabold tracking-tight text-[var(--color-text-strong)] md:text-5xl"
    >
      {title}
    </h1>

    <div
      class="relative mx-auto w-full max-w-[600px]"
      role="search"
      data-docs-search
      data-search-empty="No matching articles yet."
      data-search-error="Search is available after running npm run build and npm run preview."
      data-search-suggestions={JSON.stringify(suggestions)}
    >
      <label class="sr-only" for={inputId}>Search the docs</label>
      <p id={hintId} class="sr-only">
        Type to search the documentation. Press slash or Control/Command plus K to focus this search field.
      </p>
      <p id={statusId} class="sr-only" data-search-status aria-live="polite"></p>
      <div
        class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-[var(--color-search-placeholder)]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z"></path>
        </svg>
      </div>
      <input
        id={inputId}
        type="search"
        role="combobox"
        data-search-input
        class="search-input block w-full rounded-[15px] border border-[var(--color-border-strong)] bg-[var(--color-surface)] py-4 pl-12 pr-28 text-base text-[var(--color-search-text)] outline-none transition-all placeholder:text-[var(--color-search-placeholder)] focus:border-blue-400 focus:ring-2 focus:ring-blue-400/20 md:text-lg"
        placeholder={placeholder}
        autocomplete="off"
        aria-autocomplete="list"
        aria-controls={resultsId}
        aria-describedby={`${hintId} ${statusId}`}
        aria-expanded="false"
        aria-haspopup="listbox"
      />
      <button
        type="button"
        data-search-submit
        class="search-submit absolute bottom-2 right-2 top-2 cursor-pointer rounded-[15px] bg-[var(--color-brand)] px-6 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-hover)]"
      >
        Search
      </button>
      <div
        id={resultsId}
        data-search-results
        class="search-results absolute left-0 right-0 top-full z-50 mt-2 hidden max-h-96 overflow-y-auto rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] text-left"
        role="listbox"
        aria-label="Search results"
        aria-hidden="true"
      >
      </div>
    </div>
  </div>
</section>

<script>
  import '../scripts/docs-search';
</script>
