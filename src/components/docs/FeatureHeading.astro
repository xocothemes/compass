---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
}

const {
  eyebrow,
  title,
  body,
} = Astro.props;
---

<div class="docs-feature-heading not-prose my-10 border-l-4 border-[var(--color-accent)] pl-5">
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)]">
      {eyebrow}
    </p>
  )}
  <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950 dark:text-slate-50">
    {title}
  </h2>
  {body && <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600 dark:text-slate-300">{body}</p>}
</div>
