---
interface Props {
  title: string;
  open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="docs-accordion not-prose my-4" open={open}>
  <summary class="docs-accordion-summary cursor-pointer list-none px-5 py-4 text-sm font-semibold">
    <span>{title}</span>
    <span class="docs-accordion-marker" aria-hidden="true">+</span>
  </summary>
  <div class="docs-accordion-content px-5 pb-4 pt-1 text-sm leading-6">
    <slot />
  </div>
</details>
