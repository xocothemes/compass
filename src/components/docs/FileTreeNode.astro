---
type FileTreeNodeItem = {
  name: string;
  isDirectory: boolean;
  children: FileTreeNodeItem[];
};

interface Props {
  nodes: FileTreeNodeItem[];
}

const { nodes } = Astro.props;
---

<ul class="docs-file-tree-branch" role="list">
  {
    nodes.map((node) => (
      <li class="docs-file-tree-item">
        <div class:list={['docs-file-tree-row', node.isDirectory && 'is-directory']}>
          <span class="docs-file-tree-icon" aria-hidden="true">
            {node.isDirectory ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3.75 7.5A2.25 2.25 0 0 1 6 5.25h4.19c.6 0 1.17.24 1.6.66l1.12 1.09c.42.42 1 .66 1.6.66H18A2.25 2.25 0 0 1 20.25 9.9v6.6A2.25 2.25 0 0 1 18 18.75H6A2.25 2.25 0 0 1 3.75 16.5v-9Z"
                />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6.75 3.75h7.94c.4 0 .78.16 1.06.44l3.06 3.06c.28.28.44.66.44 1.06v11.94A1.5 1.5 0 0 1 17.75 21.75h-11.5a1.5 1.5 0 0 1-1.5-1.5V5.25a1.5 1.5 0 0 1 1.5-1.5Z"
                />
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 3.75v4.5h4.5" />
              </svg>
            )}
          </span>
          <span class="docs-file-tree-name">{node.name}</span>
        </div>

        {node.children.length > 0 && <Astro.self nodes={node.children} />}
      </li>
    ))
  }
</ul>
