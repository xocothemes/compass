---
interface Props {
  title: string;
  number: string | number;
}

const { title, number } = Astro.props;
---

<li class="docs-step grid grid-cols-[2.5rem_1fr] gap-x-4 gap-y-3 pb-8">
  <div class="docs-step-number inline-flex h-10 w-10 items-center justify-center text-sm font-semibold">{number}</div>
  <div class="docs-step-title self-center text-xl font-semibold tracking-tight">{title}</div>
  <div class="docs-step-line ml-[1.2rem] mt-1 w-px self-stretch"></div>
  <div class="docs-step-body text-base leading-7">
    <slot />
  </div>
</li>
