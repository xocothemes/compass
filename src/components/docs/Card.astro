---
interface Props {
  href: string;
  title: string;
  description?: string;
  eyebrow?: string;
}

const { href, title, description, eyebrow } = Astro.props;
---

<a
  href={href}
  class="docs-link-card group block rounded-[15px] border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition"
>
  {eyebrow && <p class="docs-link-card-eyebrow">{eyebrow}</p>}
  <div class="mt-1 flex items-start justify-between gap-4">
    <h3 class="docs-link-card-title text-lg font-semibold tracking-tight">{title}</h3>
    <svg class="docs-link-card-icon mt-0.5 h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.8"
        d="M7 17 17 7M9 7h8v8"></path>
    </svg>
  </div>
  {description && <p class="docs-link-card-description mt-3 text-sm leading-6">{description}</p>}
</a>
