---
interface Props {
  labels: string[];
  ariaLabel?: string;
}

const { labels = [], ariaLabel = 'Code examples' } = Astro.props;
const tabId = `code-tabs-${Math.random().toString(36).slice(2, 10)}`;
const panels = await Promise.all(labels.map((_, index) => Astro.slots.render(`panel-${index + 1}`)));
---

<div class="docs-tabs docs-code-tabs not-prose my-8" data-tabs-root={tabId}>
  <div
    class="docs-tabs-list flex flex-wrap gap-6 border-b border-[var(--color-border)]"
    role="tablist"
    aria-label={ariaLabel}
  >
    {
      labels.map((label, index) => (
        <button
          type="button"
          id={`${tabId}-tab-${index}`}
          class:list={['docs-tab pb-3 text-sm font-semibold transition', index === 0 && 'is-active']}
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`${tabId}-panel-${index}`}
          tabindex={index === 0 ? '0' : '-1'}
          data-tab-trigger
          data-tab-index={index}
          data-tab-target={`${tabId}-panel-${index}`}
        >
          {label}
        </button>
      ))
    }
  </div>

  {
    panels.map((panel, index) => (
      <section
        class:list={['docs-tab-panel docs-code-tab-panel', index !== 0 && 'hidden']}
        role="tabpanel"
        id={`${tabId}-panel-${index}`}
        aria-labelledby={`${tabId}-tab-${index}`}
        tabindex={0}
        data-tab-panel
        hidden={index !== 0}
        set:html={panel}
      />
    ))
  }
</div>

<script is:inline>
  document.querySelectorAll('[data-tabs-root]').forEach((tabsRoot) => {
    if (!(tabsRoot instanceof HTMLElement) || tabsRoot.dataset.tabsReady === 'true') return;
    tabsRoot.dataset.tabsReady = 'true';

    const triggers = Array.from(tabsRoot.querySelectorAll('[data-tab-trigger]'));
    const panels = Array.from(tabsRoot.querySelectorAll('[data-tab-panel]'));

    const activateTab = (nextTrigger, moveFocus = false) => {
      if (!(nextTrigger instanceof HTMLButtonElement)) return;

      const target = nextTrigger.dataset.tabTarget;

      triggers.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const isActive = button === nextTrigger;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
        button.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        const isActive = panel.id === target;
        panel.classList.toggle('hidden', !isActive);
        panel.hidden = !isActive;
      });

      if (moveFocus) nextTrigger.focus();
    };

    triggers.forEach((trigger, index) => {
      if (!(trigger instanceof HTMLButtonElement)) return;

      trigger.addEventListener('click', () => activateTab(trigger));
      trigger.addEventListener('keydown', (event) => {
        let nextIndex = null;

        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
          nextIndex = (index + 1) % triggers.length;
        } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          nextIndex = (index - 1 + triggers.length) % triggers.length;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = triggers.length - 1;
        }

        if (nextIndex === null) return;
        event.preventDefault();
        activateTab(triggers[nextIndex], true);
      });
    });
  });
</script>
