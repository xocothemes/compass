---
interface Props {
  headers: string[];
  rows: string[][];
  caption?: string;
  align?: Array<'left' | 'center' | 'right'>;
}

const { headers = [], rows = [], caption, align = [] } = Astro.props;

const getAlignmentClass = (index: number) => {
  const value = align[index] ?? 'left';

  if (value === 'center') return 'is-center';
  if (value === 'right') return 'is-right';
  return 'is-left';
};
---

<div class="docs-table-wrap not-prose my-6 overflow-x-auto">
  <table class="docs-table w-full border-collapse">
    {caption && <caption class="docs-table-caption">{caption}</caption>}
    <thead>
      <tr>
        {
          headers.map((header, index) => (
            <th scope="col" class:list={['docs-table-cell docs-table-head', getAlignmentClass(index)]}>
              {header}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            {row.map((cell, index) => (
              <td class:list={['docs-table-cell docs-table-body-cell', getAlignmentClass(index)]}>{cell}</td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
