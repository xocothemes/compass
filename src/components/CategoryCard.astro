---
interface Props {
  title: string;
  description: string;
  count: number;
  href: string;
  icon: 'flag' | 'file' | 'user' | 'inbox' | 'spark' | 'grid';
}

const { title, description, count, href, icon } = Astro.props;

const iconPaths = {
  flag: [
    'M6.75 20V5.75',
    'M6.75 6.5c2-1.5 4.1-1.5 6.1 0s4.1 1.5 6.15 0v8c-2.05 1.5-4.15 1.5-6.15 0s-4.1-1.5-6.1 0',
  ],
  file: [
    'M8.75 4.75h5.5l4 4v10.5A1.75 1.75 0 0 1 16.5 21h-7A1.75 1.75 0 0 1 7.75 19.25v-12.75A1.75 1.75 0 0 1 9.5 4.75Z',
    'M14 4.75v4h4',
    'M10.5 13h5',
    'M10.5 16h5',
  ],
  user: [
    'M12 12a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5Z',
    'M6.5 18.5c1.35-2.35 3.2-3.5 5.5-3.5s4.15 1.15 5.5 3.5',
  ],
  inbox: [
    'M5.5 7.5h13l1 8.5a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2l1-8.5Z',
    'M7.75 7.5V6.75A1.75 1.75 0 0 1 9.5 5h5A1.75 1.75 0 0 1 16.25 6.75v.75',
    'M8.75 12.5h6.5',
  ],
  spark: [
    'M12 4.75 13.6 9l4.15 1.6L13.6 12.2 12 16.5l-1.6-4.3-4.15-1.6L10.4 9 12 4.75Z',
    'M18.25 5.75 18.8 7.2l1.45.55-1.45.55-.55 1.45-.55-1.45-1.45-.55 1.45-.55.55-1.45Z',
  ],
  grid: [
    'M7.5 5.75h3.25v3.25H7.5z',
    'M13.25 5.75h3.25v3.25h-3.25z',
    'M7.5 11.5h3.25v3.25H7.5z',
    'M13.25 11.5h3.25v3.25h-3.25z',
    'M10.75 7.4h2.5',
    'M10.75 13.15h2.5',
  ],
} satisfies Record<Props['icon'], string[]>;
---

<a
  href={href}
  class="site-card group flex h-full flex-col rounded-none border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-7 transition duration-200 hover:border-[var(--color-border-strong)]"
>
  <div class="category-card-icon flex h-11 w-11 items-center justify-center rounded-none bg-[var(--color-soft)] text-[var(--color-accent)]">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      {iconPaths[icon].map((path) => (
        <path d={path} stroke-linecap="round" stroke-linejoin="round" />
      ))}
    </svg>
  </div>

  <h3 class="mt-5 text-xl font-semibold leading-tight tracking-tight text-slate-950">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-6 text-slate-600">{description}</p>

  <div class="mt-6 flex items-center justify-between">
    <span class="category-card-count text-sm font-semibold text-[var(--color-accent)]">{count} articles</span>
  </div>
</a>
