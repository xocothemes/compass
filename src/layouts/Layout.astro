---
import '../index.css';
import Header from '../components/Header.astro';
import site from '../../site.config.mjs';

interface Props {
  title: string;
  description?: string;
  showFooter?: boolean;
  mainClass?: string;
  footerClass?: string;
}

const { title, description = site.description, showFooter = true, mainClass = '', footerClass = 'mt-20' } = Astro.props;

const ogImageUrl = new URL(site.ogImage, site.siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" id="site-favicon" />
    <link rel="canonical" href={new URL(Astro.url.pathname, site.siteUrl).toString()} />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.title} social preview`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      const storedTheme = localStorage.getItem('compass-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const shouldUseDark = storedTheme ? storedTheme === 'dark' : systemPrefersDark;
      document.documentElement.classList.toggle('dark', shouldUseDark);

      window.__syncCompassFavicon = (isDark) => {
        const favicon = document.getElementById('site-favicon');

        if (favicon instanceof HTMLLinkElement) {
          favicon.href = isDark ? '/favicon-dark.svg' : '/favicon-light.svg';
        }
      };

      window.__syncCompassFavicon(shouldUseDark);
    </script>
  </head>
  <body class="relative flex min-h-screen flex-col bg-[var(--color-canvas)] text-[var(--color-text)] antialiased">
    <div class="flex min-h-screen flex-col">
      <Header />
      <main class:list={['flex-1', mainClass]}>
        <slot />
      </main>
      {
        showFooter && (
          <footer
            class:list={[
              'site-footer border-t border-[var(--color-border)] px-4 py-10 text-center text-sm text-[var(--color-text-muted)] md:px-8',
              footerClass,
            ]}
          >
            <a
              href={site.githubUrl}
              target="_blank"
              rel="noreferrer"
              class="mx-auto mb-4 inline-flex text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
              aria-label={`${site.name} on GitHub`}
              title={`${site.name} on GitHub`}
            >
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.648.5.5 5.648.5 12a11.5 11.5 0 0 0 7.863 10.915c.575.106.787-.25.787-.556 0-.275-.012-1.187-.019-2.156-3.2.694-3.877-1.356-3.877-1.356-.525-1.337-1.281-1.694-1.281-1.694-1.05-.719.081-.706.081-.706 1.162.081 1.775 1.194 1.775 1.194 1.031 1.769 2.706 1.258 3.366.963.106-.744.406-1.256.737-1.544-2.556-.287-5.244-1.281-5.244-5.706 0-1.262.45-2.294 1.188-3.103-.119-.288-.515-1.444.112-3.012 0 0 .969-.31 3.175 1.185A10.96 10.96 0 0 1 12 6.032c.975.005 1.956.132 2.873.388 2.206-1.494 3.173-1.185 3.173-1.185.629 1.568.233 2.724.114 3.012.739.809 1.186 1.841 1.186 3.103 0 4.437-2.694 5.415-5.257 5.697.418.362.79 1.073.79 2.163 0 1.563-.013 2.822-.013 3.206 0 .309.206.669.794.555A11.502 11.502 0 0 0 23.5 12C23.5 5.648 18.352.5 12 .5Z" />
              </svg>
            </a>
            <p>{site.footerText}</p>
            <p class="mt-2">
              &copy; {new Date().getFullYear()} {site.name}. Released under the MIT License.
            </p>
          </footer>
        )
      }
    </div>
  </body>
</html>
