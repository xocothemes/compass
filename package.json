{
  "name": "compass-docs-theme",
  "version": "2.0.0",
  "description": "A clean Astro documentation template for product docs and support centers.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "author": "Andrei Alba",
  "homepage": "https://compass-lilac-tau.vercel.app/",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreialba/compass.git"
  },
  "files": [
    "src",
    "public",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "screenshot.webp",
    "astro.config.mjs",
    "site.config.mjs",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 3000",
    "start": "astro dev --host 0.0.0.0 --port 3000",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview --host 0.0.0.0 --port 3000",
    "check": "astro check",
    "lint": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node -e \"import('node:fs').then((fs) => ['dist', '.astro'].forEach((dir) => fs.rmSync(dir, { recursive: true, force: true })))\""
  },
  "keywords": [
    "astro",
    "tailwindcss",
    "documentation",
    "docs-theme",
    "mdx",
    "starter",
    "template",
    "theme"
  ],
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.14",
    "astro": "^7.0.9",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "astro": {
      "esbuild": "^0.28.1"
    },
    "yaml-language-server": {
      "yaml": "2.9.0"
    }
  }
}
